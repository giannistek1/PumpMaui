<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TapItUp.ResultsPage"
             BackgroundColor="#05010F"
             NavigationPage.HasNavigationBar="False">

    <!-- Use ScrollView to prevent content from being cut off -->
    <ScrollView>
        <Grid Padding="{OnPlatform Default='20', iOS='10', Android='10'}"
              RowDefinitions="Auto,*,Auto">

            <!-- Header (removed top "RESULTS" label; kept song title/meta) -->
            <StackLayout Grid.Row="0" 
                         Spacing="{OnPlatform Default='10', iOS='8', Android='8'}" 
                         Margin="{OnPlatform Default='0,20,0,30', iOS='0,10,0,20', Android='0,10,0,20'}">
                
                <StackLayout Spacing="2" HorizontalOptions="Center">
                    <Label x:Name="SongTitleLabel"
                           Text="Song Title"
                           FontSize="{OnPlatform Default='18', iOS='16', Android='16'}"
                           FontAttributes="Bold"
                           TextColor="#FFF4FF"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap"
                           MaxLines="2" />
                    <Label x:Name="SongMetaLabel"
                           Text="Artist - Difficulty Level"
                           FontSize="{OnPlatform Default='14', iOS='12', Android='12'}"
                           TextColor="#B89EEA"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap"
                           MaxLines="2" />
                </StackLayout>
            </StackLayout>

            <!-- Main Results - Responsive Layout -->
            <Grid Grid.Row="1" x:Name="MainResultsGrid">
                <!-- Portrait Layout -->
                <StackLayout x:Name="PortraitResults" 
                             Spacing="{OnPlatform Default='20', iOS='15', Android='15'}" 
                             VerticalOptions="Center"
                             IsVisible="True">
                    
                    <!-- Main Results Card -->
                    <Border Background="#140A29"
                            Stroke="#3E2B72"
                            StrokeThickness="2"
                            Padding="{OnPlatform Default='25,20', iOS='20,15', Android='20,15'}"
                            HorizontalOptions="Center"
                            MaximumWidthRequest="350">
                        <StackLayout Spacing="{OnPlatform Default='12', iOS='10', Android='10'}" HorizontalOptions="Center">
                            <!-- SCORE Label -->
                            <Label Text="SCORE"
                                   FontSize="{OnPlatform Default='14', iOS='12', Android='12'}"
                                   FontAttributes="Bold"
                                   TextColor="#FCE3FF"
                                   HorizontalTextAlignment="Center" />
                            
                            <!-- Score Number (Large) -->
                            <Label x:Name="ScoreLabel"
                                   Text="1,000,000"
                                   FontSize="{OnPlatform Default='36', iOS='32', Android='32'}"
                                   FontAttributes="Bold"
                                   TextColor="#FFE76A"
                                   HorizontalTextAlignment="Center" />
                            
                            <!-- Grade (Biggest - Title Size, No Label) -->
                            <Label x:Name="GradeLabel"
                                   Text="SSS+"
                                   FontSize="{OnPlatform Default='56', iOS='48', Android='48'}"
                                   FontAttributes="Bold"
                                   TextColor="#87CEEB"
                                   HorizontalTextAlignment="Center"
                                   Margin="0,5,0,5" />
                            
                            <!-- Plate Initials (Similar to Score, No Label) -->
                            <Label x:Name="PlateLabel"
                                   Text="PG"
                                   FontSize="{OnPlatform Default='34', iOS='30', Android='30'}"
                                   FontAttributes="Bold"
                                   TextColor="#87CEEB"
                                   HorizontalTextAlignment="Center" />
                        </StackLayout>
                    </Border>

                    <!-- Detailed Stats -->
                    <Border Background="#140A29"
                            Stroke="#3E2B72"
                            StrokeThickness="2"
                            Padding="{OnPlatform Default='20', iOS='15', Android='15'}"
                            HorizontalOptions="Center"
                            MaximumWidthRequest="350">
                        <StackLayout Spacing="8">
                            <Label Text="DETAILED RESULTS"
                                   FontSize="{OnPlatform Default='14', iOS='12', Android='12'}"
                                   FontAttributes="Bold"
                                   TextColor="#FCE3FF"
                                   HorizontalTextAlignment="Center" />
                            
                            <Grid ColumnDefinitions="2*,*" 
                                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" 
                                  ColumnSpacing="{OnPlatform Default='20', iOS='15', Android='15'}" 
                                  RowSpacing="{OnPlatform Default='5', iOS='4', Android='4'}">
                                <!-- Accuracy -->
                                <Label Grid.Row="0" Grid.Column="0" Text="Accuracy:" TextColor="#D0B7FF" FontSize="{OnPlatform Default='12', iOS='11', Android='11'}" />
                                <Label Grid.Row="0" Grid.Column="1" x:Name="AccuracyLabel" Text="100.00%" TextColor="#B4FF8E" FontSize="{OnPlatform Default='12', iOS='11', Android='11'}" HorizontalTextAlignment="End" />
                                
                                <!-- Max Combo -->
                                <Label Grid.Row="1" Grid.Column="0" Text="Max Combo:" TextColor="#D0B7FF" FontSize="{OnPlatform Default='12', iOS='11', Android='11'}" />
                                <Label Grid.Row="1" Grid.Column="1" x:Name="MaxComboLabel" Text="999" TextColor="#B4FF8E" FontSize="{OnPlatform Default='12', iOS='11', Android='11'}" HorizontalTextAlignment="End" />
                                
                                <!-- Perfect -->
                                <Label Grid.Row="2" Grid.Column="0" Text="Perfect:" TextColor="#87CEEB" FontSize="{OnPlatform Default='12', iOS='11', Android='11'}" FontAttributes="Bold" />
                                <Label Grid.Row="2" Grid.Column="1" x:Name="PerfectLabel" Text="999" TextColor="#87CEEB" FontSize="{OnPlatform Default='12', iOS='11', Android='11'}" HorizontalTextAlignment="End" FontAttributes="Bold" />
                                
                                <!-- Great -->
                                <Label Grid.Row="3" Grid.Column="0" Text="Great:" TextColor="#00FF00" FontSize="{OnPlatform Default='12', iOS='11', Android='11'}" />
                                <Label Grid.Row="3" Grid.Column="1" x:Name="GreatLabel" Text="999" TextColor="#00FF00" FontSize="{OnPlatform Default='12', iOS='11', Android='11'}" HorizontalTextAlignment="End" />
                                
                                <!-- Good -->
                                <Label Grid.Row="4" Grid.Column="0" Text="Good:" TextColor="#FFFF00" FontSize="{OnPlatform Default='12', iOS='11', Android='11'}" />
                                <Label Grid.Row="4" Grid.Column="1" x:Name="GoodLabel" Text="999" TextColor="#FFFF00" FontSize="{OnPlatform Default='12', iOS='11', Android='11'}" HorizontalTextAlignment="End" />
                                
                                <!-- Bad -->
                                <Label Grid.Row="5" Grid.Column="0" Text="Bad:" TextColor="#8A2BE2" FontSize="{OnPlatform Default='12', iOS='11', Android='11'}" />
                                <Label Grid.Row="5" Grid.Column="1" x:Name="BadLabel" Text="999" TextColor="#8A2BE2" FontSize="{OnPlatform Default='12', iOS='11', Android='11'}" HorizontalTextAlignment="End" />
                                
                                <!-- Miss -->
                                <Label Grid.Row="6" Grid.Column="0" Text="Miss:" TextColor="#FF0000" FontSize="{OnPlatform Default='12', iOS='11', Android='11'}" />
                                <Label Grid.Row="6" Grid.Column="1" x:Name="MissLabel" Text="999" TextColor="#FF0000" FontSize="{OnPlatform Default='12', iOS='11', Android='11'}" HorizontalTextAlignment="End" />
                            </Grid>
                        </StackLayout>
                    </Border>
                </StackLayout>

                <!-- Landscape Layout -->
                <Grid x:Name="LandscapeResults" 
                      ColumnDefinitions="*,*" 
                      ColumnSpacing="20"
                      IsVisible="False">
                    
                    <!-- Left Column -->
                    <StackLayout Grid.Column="0" Spacing="15" VerticalOptions="Center">
                        <!-- Main Results Card -->
                        <Border Background="#140A29"
                                Stroke="#3E2B72"
                                StrokeThickness="2"
                                Padding="20,15">
                            <StackLayout Spacing="10" HorizontalOptions="Center">
                                <!-- SCORE Label -->
                                <Label Text="SCORE"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#FCE3FF"
                                       HorizontalTextAlignment="Center" />
                                
                                <!-- Score Number (Large) -->
                                <Label x:Name="ScoreLabelLandscape"
                                       Text="1,000,000"
                                       FontSize="28"
                                       FontAttributes="Bold"
                                       TextColor="#FFE76A"
                                       HorizontalTextAlignment="Center" />
                                
                                <!-- Grade (Biggest - Title Size, No Label) -->
                                <Label x:Name="GradeLabelLandscape"
                                       Text="SSS+"
                                       FontSize="42"
                                       FontAttributes="Bold"
                                       TextColor="#87CEEB"
                                       HorizontalTextAlignment="Center"
                                       Margin="0,4,0,4" />
                                
                                <!-- Plate Initials (Similar to Score, No Label) -->
                                <Label x:Name="PlateLabelLandscape"
                                       Text="PG"
                                       FontSize="26"
                                       FontAttributes="Bold"
                                       TextColor="#87CEEB"
                                       HorizontalTextAlignment="Center" />
                            </StackLayout>
                        </Border>
                    </StackLayout>

                    <!-- Right Column - Detailed Stats -->
                    <Border Grid.Column="1"
                            Background="#140A29"
                            Stroke="#3E2B72"
                            StrokeThickness="2"
                            Padding="15"
                            VerticalOptions="Center">
                        <StackLayout Spacing="6">
                            <Label Text="DETAILED RESULTS"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#FCE3FF"
                                   HorizontalTextAlignment="Center" />
                            
                            <Grid ColumnDefinitions="2*,*" 
                                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" 
                                  ColumnSpacing="15" 
                                  RowSpacing="3">
                                <!-- Accuracy -->
                                <Label Grid.Row="0" Grid.Column="0" Text="Accuracy:" TextColor="#D0B7FF" FontSize="11" />
                                <Label Grid.Row="0" Grid.Column="1" x:Name="AccuracyLabelLandscape" Text="100.00%" TextColor="#B4FF8E" FontSize="11" HorizontalTextAlignment="End" />
                                
                                <!-- Max Combo -->
                                <Label Grid.Row="1" Grid.Column="0" Text="Max Combo:" TextColor="#D0B7FF" FontSize="11" />
                                <Label Grid.Row="1" Grid.Column="1" x:Name="MaxComboLabelLandscape" Text="999" TextColor="#B4FF8E" FontSize="11" HorizontalTextAlignment="End" />
                                
                                <!-- Perfect -->
                                <Label Grid.Row="2" Grid.Column="0" Text="Perfect:" TextColor="#87CEEB" FontSize="11" FontAttributes="Bold" />
                                <Label Grid.Row="2" Grid.Column="1" x:Name="PerfectLabelLandscape" Text="999" TextColor="#87CEEB" FontSize="11" HorizontalTextAlignment="End" FontAttributes="Bold" />
                                
                                <!-- Great -->
                                <Label Grid.Row="3" Grid.Column="0" Text="Great:" TextColor="#00FF00" FontSize="11" />
                                <Label Grid.Row="3" Grid.Column="1" x:Name="GreatLabelLandscape" Text="999" TextColor="#00FF00" FontSize="11" HorizontalTextAlignment="End" />
                                
                                <!-- Good -->
                                <Label Grid.Row="4" Grid.Column="0" Text="Good:" TextColor="#FFFF00" FontSize="11" />
                                <Label Grid.Row="4" Grid.Column="1" x:Name="GoodLabelLandscape" Text="999" TextColor="#FFFF00" FontSize="11" HorizontalTextAlignment="End" />
                                
                                <!-- Bad -->
                                <Label Grid.Row="5" Grid.Column="0" Text="Bad:" TextColor="#8A2BE2" FontSize="11" />
                                <Label Grid.Row="5" Grid.Column="1" x:Name="BadLabelLandscape" Text="999" TextColor="#8A2BE2" FontSize="11" HorizontalTextAlignment="End" />
                                
                                <!-- Miss -->
                                <Label Grid.Row="6" Grid.Column="0" Text="Miss:" TextColor="#FF0000" FontSize="11" />
                                <Label Grid.Row="6" Grid.Column="1" x:Name="MissLabelLandscape" Text="999" TextColor="#FF0000" FontSize="11" HorizontalTextAlignment="End" />
                            </Grid>
                        </StackLayout>
                    </Border>
                </Grid>
            </Grid>

            <!-- Navigation Buttons -->
            <StackLayout Grid.Row="2" 
                         Orientation="Horizontal" 
                         HorizontalOptions="Center" 
                         Spacing="{OnPlatform Default='20', iOS='15', Android='15'}" 
                         Margin="{OnPlatform Default='0,30,0,10', iOS='0,20,0,10', Android='0,20,0,10'}">
                <Button Text="Song Select"
                        BackgroundColor="#2E4B27"
                        TextColor="White"
                        CornerRadius="8"
                        Padding="{OnPlatform Default='20,12', iOS='15,10', Android='15,10'}"
                        FontSize="{OnPlatform Default='14', iOS='13', Android='13'}"
                        Clicked="OnSongSelectClicked" />
            </StackLayout>
        </Grid>
    </ScrollView>
</ContentPage>