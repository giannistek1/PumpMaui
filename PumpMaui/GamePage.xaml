<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="PumpMaui.GamePage"
             BackgroundColor="#05010F"
             NavigationPage.HasNavigationBar="False">

    <Grid x:Name="MainGrid">
        <!-- Portrait Layout -->
        <Grid x:Name="PortraitLayout" 
              IsVisible="True"
              Padding="{OnPlatform Default=12, iOS=6, Android=6}">

            <!-- Background -->
            <Image x:Name="BackgroundPreview"
                   Aspect="AspectFill"
                   Opacity="0.3"
                   HorizontalOptions="FillAndExpand"
                   VerticalOptions="FillAndExpand" />

            <!-- Fixed width note field centered -->
            <GraphicsView x:Name="NoteFieldView"
                          WidthRequest="300"
                          HorizontalOptions="Center"
                          VerticalOptions="FillAndExpand" />

            <!-- Exit button positioned at top right -->
            <Button Text="✕"
                    Clicked="OnStopClicked"
                    BackgroundColor="#4B275E"
                    TextColor="White"
                    CornerRadius="8"
                    WidthRequest="{OnPlatform Default=40, iOS=35, Android=35}"
                    HeightRequest="{OnPlatform Default=40, iOS=35, Android=35}"
                    FontSize="{OnPlatform Default=16, iOS=14, Android=14}"
                    HorizontalOptions="End"
                    VerticalOptions="Start"
                    Margin="0,10,10,0" />

            <!-- Portrait Pad - More transparent and positioned lower -->
            <Grid x:Name="PortraitPad"
                  HorizontalOptions="Center"
                  VerticalOptions="End"
                  Margin="{OnPlatform Default='0,0,0,10', iOS='0,0,0,5', Android='0,0,0,5'}" />

            <!-- Center Overlay - Judgment and Combo (Above everything else) -->
            <StackLayout x:Name="CenterOverlayPortrait"
                         HorizontalOptions="Center"
                         VerticalOptions="Center"
                         Spacing="4"
                         IsVisible="True">
                
                <!-- Judgment Text -->
                <Label x:Name="CenterJudgmentLabel"
                       Text="READY"
                       FontSize="{OnPlatform Default=48, iOS=40, Android=40}"
                       FontAttributes="Bold"
                       TextColor="#FFE76A"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"
                       Opacity="0.9"
                       Shadow="{Shadow Brush=Black, Offset='2,2', Radius=8, Opacity=0.8}" />
                
                <!-- Combo Number (Only visible when combo >= 4) -->
                <Label x:Name="CenterComboNumberLabel"
                       Text="4"
                       FontSize="{OnPlatform Default=42, iOS=36, Android=36}"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"
                       IsVisible="False"
                       Opacity="0.9"
                       Shadow="{Shadow Brush=Black, Offset='2,2', Radius=8, Opacity=0.8}" />
                
                <!-- Combo Text (Only visible when combo >= 4) -->
                <Label x:Name="CenterComboTextLabel"
                       Text="COMBO"
                       FontSize="{OnPlatform Default=20, iOS=16, Android=16}"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"
                       IsVisible="False"
                       Opacity="0.8"
                       Shadow="{Shadow Brush=Black, Offset='1,1', Radius=4, Opacity=0.8}" />
            </StackLayout>

            <!-- Stats overlay in portrait - positioned at bottom -->
            <Label x:Name="PortraitCountsLabel"
                   Text="PERFECT 0 • GREAT 0 • GOOD 0 • BAD 0 • MISS 0"
                   FontSize="{OnPlatform Default=10, iOS=8, Android=8}"
                   TextColor="#D0B7FF"
                   HorizontalTextAlignment="Center"
                   VerticalOptions="End"
                   Margin="0,0,0,2"
                   Opacity="0.8"
                   Shadow="{Shadow Brush=Black, Offset='1,1', Radius=4, Opacity=0.8}" />

            <!-- Invisible text entry for keyboard input -->
            <Entry x:Name="KeyCatcher"
                   IsVisible="False"
                   TextChanged="KeyCatcher_TextChanged"
                   Unfocused="KeyCatcher_Unfocused" />
        </Grid>

        <!-- Landscape Layout - Fixed center width with scaling sides -->
        <Grid x:Name="LandscapeLayout" 
              IsVisible="False"
              ColumnDefinitions="*,Auto,*"
              RowDefinitions="Auto,*,Auto">

            <!-- Top HUD across full width -->
            <Border Grid.Row="0" Grid.ColumnSpan="3"
                    Background="#140A29"
                    Stroke="#3E2B72"
                    StrokeThickness="1"
                    Padding="8"
                    Margin="4,4,4,8">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                    <VerticalStackLayout Grid.Column="0" Spacing="1">
                        <Label x:Name="LandscapeTitleLabel"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#FFF4FF"
                               LineBreakMode="TailTruncation" />
                        <Label x:Name="LandscapeMetaLabel"
                               FontSize="10"
                               TextColor="#B89EEA"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="1">
                        <Label Text="Score" FontSize="8" FontAttributes="Bold" TextColor="#FCE3FF" />
                        <Label x:Name="LandscapeScoreLabel" Text="0000000" FontSize="12" 
                               FontAttributes="Bold" TextColor="#FFE76A" />
                    </VerticalStackLayout>
                    
                    <VerticalStackLayout Grid.Column="2" Spacing="1">
                        <Label Text="Grade" FontSize="8" FontAttributes="Bold" TextColor="#FCE3FF" />
                        <Label x:Name="LandscapeGradeLabel" Text="D" FontSize="12" 
                               FontAttributes="Bold" TextColor="#7EE7FF" />
                    </VerticalStackLayout>
                    
                    <VerticalStackLayout Grid.Column="3" Spacing="1">
                        <Label Text="Acc" FontSize="8" FontAttributes="Bold" TextColor="#FCE3FF" />
                        <Label x:Name="LandscapeAccuracyLabel" Text="0.00%" FontSize="11" 
                               FontAttributes="Bold" TextColor="#B4FF8E" />
                    </VerticalStackLayout>

                    <Button Grid.Column="4"
                            Text="✕"
                            Clicked="OnStopClicked"
                            BackgroundColor="#4B275E"
                            TextColor="White"
                            CornerRadius="6"
                            WidthRequest="35"
                            HeightRequest="35"
                            FontSize="14" />
                </Grid>
            </Border>

            <!-- Left side - Scaling pad area -->
            <Grid Grid.Column="0" Grid.Row="1" 
                  Padding="8,8,8,4"
                  MinimumWidthRequest="120">
                
                <!-- Left input pad - Scales with available space -->
                <Grid x:Name="LandscapeLeftPad" 
                      HorizontalOptions="Fill"
                      VerticalOptions="Fill" />
            </Grid>

            <!-- Center - Fixed width note field -->
            <Grid Grid.Column="1" Grid.Row="1" 
                  WidthRequest="400"
                  Margin="8,0">

                <!-- Background for center area only -->
                <Image x:Name="LandscapeBackgroundPreview"
                       Aspect="AspectFill"
                       Opacity="0.2"
                       HorizontalOptions="FillAndExpand"
                       VerticalOptions="FillAndExpand" />
                
                <!-- Note field with fixed width -->
                <GraphicsView x:Name="LandscapeNoteFieldView"
                              HorizontalOptions="FillAndExpand"
                              VerticalOptions="FillAndExpand" />

                <!-- Center Overlay for Landscape - Judgment and Combo -->
                <StackLayout x:Name="CenterOverlayLandscape"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Spacing="3"
                             IsVisible="True">
                    
                    <!-- Judgment Text -->
                    <Label x:Name="LandscapeCenterJudgmentLabel"
                           Text="READY"
                           FontSize="32"
                           FontAttributes="Bold"
                           TextColor="#FFE76A"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center"
                           Opacity="0.9"
                           Shadow="{Shadow Brush=Black, Offset='2,2', Radius=8, Opacity=0.8}" />
                    
                    <!-- Combo Number (Only visible when combo >= 4) -->
                    <Label x:Name="LandscapeCenterComboNumberLabel"
                           Text="4"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center"
                           IsVisible="False"
                           Opacity="0.9"
                           Shadow="{Shadow Brush=Black, Offset='2,2', Radius=8, Opacity=0.8}" />
                    
                    <!-- Combo Text (Only visible when combo >= 4) -->
                    <Label x:Name="LandscapeCenterComboTextLabel"
                           Text="COMBO"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center"
                           IsVisible="False"
                           Opacity="0.8"
                           Shadow="{Shadow Brush=Black, Offset='1,1', Radius=4, Opacity=0.8}" />
                </StackLayout>
            </Grid>

            <!-- Right side - Scaling pad area -->
            <Grid Grid.Column="2" Grid.Row="1" 
                  Padding="8,8,8,4"
                  MinimumWidthRequest="120">
                
                <!-- Right input pad - Scales with available space -->
                <Grid x:Name="LandscapeRightPad" 
                      HorizontalOptions="Fill"
                      VerticalOptions="Fill" />
            </Grid>

            <!-- Bottom stats across full width -->
            <Border Grid.Row="2" Grid.ColumnSpan="3"
                    Background="#140A29"
                    Stroke="#3E2B72"
                    StrokeThickness="1"
                    Padding="6"
                    Margin="4,8,4,0">
                <Label x:Name="LandscapeCountsLabel"
                       Text="PERFECT 0 • GREAT 0 • GOOD 0 • BAD 0 • MISS 0"
                       FontSize="10"
                       TextColor="#D0B7FF"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="TailTruncation" />
            </Border>
        </Grid>

        <!-- Audio player -->
        <toolkit:MediaElement x:Name="SongMediaElement"
                             IsVisible="False"
                             ShouldAutoPlay="False" />
    </Grid>
</ContentPage>